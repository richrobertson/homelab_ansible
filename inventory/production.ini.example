# Production Inventory Example
# Copy this file to environments/production.ini and customize for your environment
#
# Replace example hostnames/IPs with your actual infrastructure details
# Add appropriate host_vars and group_vars as needed
#
# WARNING: Never commit actual credentials or sensitive details!
# Use Vault for secret management instead.

[dbservers]
postgresql01.example.com
postgresql02.example.com

[vault]
vault01.example.com
vault02.example.com

[powerdns]
dns01.example.com
dns02.example.com

[powerdns-recurse]
resolver01.example.com

[proxmox_nodes]
pve01.example.com
pve02.example.com
pve03.example.com

[synology_snapshot_replication_nas]
synology-a.example.com ansible_host=192.0.2.10 synology_replication_partner_host=192.0.2.11
synology-b.example.com ansible_host=192.0.2.11 synology_replication_partner_host=192.0.2.10

[synology_snapshot_replication_nas:vars]
ansible_user=admin
ansible_port=5022
synology_replication_dsm_port=443
synology_replication_data_port=5566

[domain_controllers_windows]
dc01.example.com

[dhcp_primary_windows]
dhcp01.example.com

[dhcp_partner_windows]
dhcp02.example.com

[dhcp_servers_windows:children]
dhcp_primary_windows
dhcp_partner_windows

[rdp_servers_windows:children]
domain_controllers_windows
dhcp_servers_windows

[rdp_servers_windows:vars]
ansible_connection=winrm
ansible_port=5985
ansible_winrm_scheme=http
ansible_winrm_transport=ntlm
ansible_winrm_server_cert_validation=ignore
ansible_user=ldap@myrobertson.net

[all:vars]
# Connection settings
ansible_user=admin
ansible_python_interpreter=/usr/bin/python3

# Vault configuration (update with your Vault server details)
vault_addr=https://vault.example.com:8200
vault_skip_verify=false

# Ceph cluster (if applicable)
ceph_cluster_name=ceph
