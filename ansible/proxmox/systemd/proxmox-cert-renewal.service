[Unit]
Description=Proxmox Phase 2 - Monthly Certificate Renewal (Optional)
Documentation=file:///Users/rich/Documents/GitHub/homelab_ansible/ansible/proxmox/MAINTENANCE_GUIDE.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/Users/rich/Documents/GitHub/homelab_ansible
EnvironmentFile=/etc/default/proxmox-maintenance
ExecStart=/bin/bash -c 'source bin/activate && ansible-playbook -u root -i ansible/proxmox/proxmox.yml ansible/proxmox/phase2_monthly_maintenance.yml -e run_cert_renewal=true'
StandardOutput=append:/var/log/proxmox-maintenance/phase2-cert-renewal.log
StandardError=append:/var/log/proxmox-maintenance/phase2-cert-renewal-error.log
SyslogIdentifier=proxmox-cert-renewal
TimeoutStartSec=3600

[Install]
WantedBy=multi-user.target
