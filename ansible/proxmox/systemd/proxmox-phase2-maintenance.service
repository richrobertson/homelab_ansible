[Unit]
Description=Proxmox Phase 2 - Monthly Maintenance Tasks
Documentation=file:///Users/rich/Documents/GitHub/homelab_ansible/ansible/proxmox/MAINTENANCE_GUIDE.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/Users/rich/Documents/GitHub/homelab_ansible
EnvironmentFile=/etc/default/proxmox-maintenance
ExecStart=/bin/bash -c 'source bin/activate && ansible-playbook -u root -i ansible/proxmox/proxmox.yml ansible/proxmox/phase2_monthly_maintenance.yml'
StandardOutput=append:/var/log/proxmox-maintenance/phase2.log
StandardError=append:/var/log/proxmox-maintenance/phase2-error.log
SyslogIdentifier=proxmox-phase2-maintenance
TimeoutStartSec=3600

[Install]
WantedBy=multi-user.target
