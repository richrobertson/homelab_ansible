#!/bin/bash
set -euo pipefail

TEXTFILE_DIR="{{ proxmox_transport_metrics_textfile_dir }}"
OUT="${TEXTFILE_DIR}/proxmox_transport.prom"
TMP="${OUT}.$$"
NODE="$(hostname -s)"
THUNDERBOLT_NETWORK="{{ proxmox_transport_metrics_thunderbolt_network }}"
THUNDERBOLT_ROUTE_REGEX="{{ proxmox_transport_metrics_thunderbolt_route_regex | default('dev en0[56]') }}"

mkdir -p "$TEXTFILE_DIR"

escape_label() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

write_metric() {
  printf '%s\n' "$1" >> "$TMP"
}

: > "$TMP"

OPTIONS_JSON="$(pvesh get /cluster/options --output-format json)"
MIGRATION_NETWORK="$(jq -r '.migration.network // ""' <<<"$OPTIONS_JSON")"
MIGRATION_TYPE="$(jq -r '.migration.type // "secure"' <<<"$OPTIONS_JSON")"
REPLICATION_NETWORK="$(jq -r '.replication.network // ""' <<<"$OPTIONS_JSON")"
REPLICATION_TYPE="$(jq -r '.replication.type // "secure"' <<<"$OPTIONS_JSON")"

write_metric '# HELP proxmox_transport_datacenter_configured Proxmox datacenter migration and replication transport configuration state.'
write_metric '# TYPE proxmox_transport_datacenter_configured gauge'
write_metric "proxmox_transport_datacenter_configured{node=\"$(escape_label "$NODE")\",transport=\"migration\",network=\"$(escape_label "$MIGRATION_NETWORK")\",type=\"$(escape_label "$MIGRATION_TYPE")\"} 1"
write_metric "proxmox_transport_datacenter_configured{node=\"$(escape_label "$NODE")\",transport=\"replication\",network=\"$(escape_label "$REPLICATION_NETWORK")\",type=\"$(escape_label "$REPLICATION_TYPE")\"} 1"

write_metric '# HELP proxmox_transport_thunderbolt_network_configured Whether migration and replication are configured for the expected Thunderbolt network.'
write_metric '# TYPE proxmox_transport_thunderbolt_network_configured gauge'
[ "$MIGRATION_NETWORK" = "$THUNDERBOLT_NETWORK" ] && migration_ok=1 || migration_ok=0
[ "$REPLICATION_NETWORK" = "$THUNDERBOLT_NETWORK" ] && replication_ok=1 || replication_ok=0
write_metric "proxmox_transport_thunderbolt_network_configured{node=\"$(escape_label "$NODE")\",transport=\"migration\",network=\"$(escape_label "$THUNDERBOLT_NETWORK")\"} $migration_ok"
write_metric "proxmox_transport_thunderbolt_network_configured{node=\"$(escape_label "$NODE")\",transport=\"replication\",network=\"$(escape_label "$THUNDERBOLT_NETWORK")\"} $replication_ok"

write_metric '# HELP proxmox_transport_peer_route_up Whether this node routes to each peer Thunderbolt loopback through a Thunderbolt interface.'
write_metric '# TYPE proxmox_transport_peer_route_up gauge'
for peer in pve3 pve4 pve5; do
  peer_id="${peer#pve}"
  peer_ip="10.0.0.8${peer_id}"
  [ "$peer" = "$NODE" ] && continue
  if ip route get "$peer_ip" 2>/dev/null | grep -Eq "$THUNDERBOLT_ROUTE_REGEX"; then
    route_up=1
  else
    route_up=0
  fi
  write_metric "proxmox_transport_peer_route_up{node=\"$(escape_label "$NODE")\",peer=\"$(escape_label "$peer")\",peer_ip=\"$(escape_label "$peer_ip")\"} $route_up"
done

write_metric '# HELP proxmox_backup_storage_info Proxmox backup storage configuration metadata.'
write_metric '# TYPE proxmox_backup_storage_info gauge'
write_metric '# HELP proxmox_backup_storage_route_up Whether the configured backup storage resolves and routes through a Thunderbolt interface.'
write_metric '# TYPE proxmox_backup_storage_route_up gauge'
awk '
  function emit() {
    if (storage != "") {
      printf "%s\t%s\t%s\n", storage, server, datastore
    }
  }
  /^pbs:[[:space:]]+/ {
    emit()
    storage=$2
    server=""
    datastore=""
    next
  }
  storage != "" && /^[[:space:]]+server[[:space:]]+/ {
    server=$2
    next
  }
  storage != "" && /^[[:space:]]+datastore[[:space:]]+/ {
    datastore=$2
    next
  }
  /^$/ {
    emit()
    storage=""
    server=""
    datastore=""
    next
  }
  END {
    emit()
  }
' /etc/pve/storage.cfg | while IFS=$'\t' read -r storage server datastore; do
  [ -n "$storage" ] || continue
  resolved_ip="$(getent ahostsv4 "$server" 2>/dev/null | awk 'NR==1{print $1}')"
  route_dev=""
  route_up=0
  if [ -n "$resolved_ip" ]; then
    route_line="$(ip route get "$resolved_ip" 2>/dev/null | head -n1 || true)"
    route_dev="$(awk '{for (i=1; i<=NF; i++) if ($i == "dev") {print $(i+1); exit}}' <<<"$route_line")"
    if grep -Eq "$THUNDERBOLT_ROUTE_REGEX" <<<"$route_line"; then
      route_up=1
    elif grep -Eq '^local ' <<<"$route_line" && ip -o addr show to "$resolved_ip" 2>/dev/null | grep -q "$resolved_ip"; then
      route_up=1
    fi
  fi
  write_metric "proxmox_backup_storage_info{node=\"$(escape_label "$NODE")\",storage=\"$(escape_label "$storage")\",server=\"$(escape_label "$server")\",datastore=\"$(escape_label "$datastore")\",expected_network=\"thunderbolt\"} 1"
  write_metric "proxmox_backup_storage_route_up{node=\"$(escape_label "$NODE")\",storage=\"$(escape_label "$storage")\",server=\"$(escape_label "$server")\",datastore=\"$(escape_label "$datastore")\",resolved_ip=\"$(escape_label "$resolved_ip")\",route_dev=\"$(escape_label "$route_dev")\",expected_network=\"thunderbolt\"} $route_up"
done

write_metric '# HELP proxmox_ceph_network_configured Ceph public and cluster network configuration observed from the Proxmox Ceph config database.'
write_metric '# TYPE proxmox_ceph_network_configured gauge'
if command -v ceph >/dev/null 2>&1; then
  ceph_cluster_network="$(ceph config get global cluster_network 2>/dev/null || true)"
  ceph_public_network="$(ceph config get global public_network 2>/dev/null || true)"
  if [ -z "$ceph_cluster_network" ]; then
    ceph_cluster_network="$(ceph config dump --format json 2>/dev/null | jq -r '[.[] | select(.name == "cluster_network")][0].value // empty' || true)"
  fi
  if [ -z "$ceph_public_network" ]; then
    ceph_public_network="$(ceph config dump --format json 2>/dev/null | jq -r '[.[] | select(.name == "public_network")][0].value // empty' || true)"
  fi
  if [ -z "$ceph_cluster_network" ] && [ -r /etc/pve/ceph.conf ]; then
    ceph_cluster_network="$(awk -F= '/^[[:space:]]*cluster_network[[:space:]]*=/{gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2; exit}' /etc/pve/ceph.conf)"
  fi
  if [ -z "$ceph_public_network" ] && [ -r /etc/pve/ceph.conf ]; then
    ceph_public_network="$(awk -F= '/^[[:space:]]*public_network[[:space:]]*=/{gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2; exit}' /etc/pve/ceph.conf)"
  fi
  [ "$ceph_cluster_network" = "$THUNDERBOLT_NETWORK" ] && ceph_cluster_ok=1 || ceph_cluster_ok=0
  [ "$ceph_public_network" = "$THUNDERBOLT_NETWORK" ] && ceph_public_ok=1 || ceph_public_ok=0
  write_metric "proxmox_ceph_network_configured{node=\"$(escape_label "$NODE")\",network_role=\"cluster\",network=\"$(escape_label "$ceph_cluster_network")\",expected_network=\"$(escape_label "$THUNDERBOLT_NETWORK")\"} $ceph_cluster_ok"
  write_metric "proxmox_ceph_network_configured{node=\"$(escape_label "$NODE")\",network_role=\"public\",network=\"$(escape_label "$ceph_public_network")\",expected_network=\"$(escape_label "$THUNDERBOLT_NETWORK")\"} $ceph_public_ok"

  write_metric '# HELP proxmox_ceph_osd_address_on_thunderbolt Whether OSD front/back addresses are on the Thunderbolt node address range.'
  write_metric '# TYPE proxmox_ceph_osd_address_on_thunderbolt gauge'
  ceph osd metadata --format json 2>/dev/null |
    jq -r --arg node "$NODE" '
      .[]
      | select(.hostname == $node)
      | [
          (.id | tostring),
          (.front_addr // ""),
          (.back_addr // "")
        ]
      | @tsv
    ' | while IFS=$'\t' read -r osd_id front_addr back_addr; do
      [ -n "$osd_id" ] || continue
      [[ "$front_addr" == *"10.0.0."* ]] && front_ok=1 || front_ok=0
      [[ "$back_addr" == *"10.0.0."* ]] && back_ok=1 || back_ok=0
      write_metric "proxmox_ceph_osd_address_on_thunderbolt{node=\"$(escape_label "$NODE")\",osd=\"$(escape_label "$osd_id")\",address_role=\"front\",address=\"$(escape_label "$front_addr")\"} $front_ok"
      write_metric "proxmox_ceph_osd_address_on_thunderbolt{node=\"$(escape_label "$NODE")\",osd=\"$(escape_label "$osd_id")\",address_role=\"back\",address=\"$(escape_label "$back_addr")\"} $back_ok"
    done
fi

TASKS_JSON="$(pvesh get "/nodes/${NODE}/tasks" --limit 200 --output-format json)"
now="$(date +%s)"
window_start="$((now - 86400))"

write_metric '# HELP proxmox_migration_tasks_24h Proxmox migration task count over the last 24 hours by status.'
write_metric '# TYPE proxmox_migration_tasks_24h gauge'
jq -r --argjson window_start "$window_start" '
  [ .[]
    | select((.type == "qmigrate" or .type == "vzmigrate") and (.starttime // 0) >= $window_start)
    | {status: (if (.status // "") == "OK" then "ok" else "failed" end)}
  ]
  | group_by(.status)
  | map({status: .[0].status, count: length})
  | .[]
  | "\(.status) \(.count)"
' <<<"$TASKS_JSON" | while read -r status count; do
  write_metric "proxmox_migration_tasks_24h{node=\"$(escape_label "$NODE")\",status=\"$(escape_label "$status")\"} $count"
done

for status in ok failed; do
  if ! grep -q "proxmox_migration_tasks_24h{node=\"$(escape_label "$NODE")\",status=\"$status\"}" "$TMP"; then
    write_metric "proxmox_migration_tasks_24h{node=\"$(escape_label "$NODE")\",status=\"$status\"} 0"
  fi
done

write_metric '# HELP proxmox_backup_restore_tasks_24h Proxmox backup and restore task count over the last 24 hours by status.'
write_metric '# TYPE proxmox_backup_restore_tasks_24h gauge'
jq -r --argjson window_start "$window_start" '
  [ .[]
    | select((.type == "vzdump" or .type == "qmrestore" or .type == "vzrestore") and (.starttime // 0) >= $window_start)
    | {
        operation: (if .type == "vzdump" then "backup" else "restore" end),
        status: (if (.status // "") == "OK" then "ok" else "failed" end)
      }
  ]
  | group_by(.operation, .status)
  | map({operation: .[0].operation, status: .[0].status, count: length})
  | .[]
  | "\(.operation) \(.status) \(.count)"
' <<<"$TASKS_JSON" | while read -r operation status count; do
  write_metric "proxmox_backup_restore_tasks_24h{node=\"$(escape_label "$NODE")\",operation=\"$(escape_label "$operation")\",status=\"$(escape_label "$status")\"} $count"
done

for operation in backup restore; do
  for status in ok failed; do
    if ! grep -q "proxmox_backup_restore_tasks_24h{node=\"$(escape_label "$NODE")\",operation=\"$operation\",status=\"$status\"}" "$TMP"; then
      write_metric "proxmox_backup_restore_tasks_24h{node=\"$(escape_label "$NODE")\",operation=\"$operation\",status=\"$status\"} 0"
    fi
  done
done

write_metric '# HELP proxmox_backup_restore_last_task_timestamp_seconds Last Proxmox backup or restore task start timestamp by operation and status.'
write_metric '# TYPE proxmox_backup_restore_last_task_timestamp_seconds gauge'
jq -r '
  [ .[]
    | select(.type == "vzdump" or .type == "qmrestore" or .type == "vzrestore")
    | {
        operation: (if .type == "vzdump" then "backup" else "restore" end),
        status: (if (.status // "") == "OK" then "ok" else "failed" end),
        ts: (.starttime // 0)
      }
  ]
  | group_by(.operation, .status)
  | map({operation: .[0].operation, status: .[0].status, ts: (map(.ts) | max)})
  | .[]
  | "\(.operation) \(.status) \(.ts)"
' <<<"$TASKS_JSON" | while read -r operation status ts; do
  write_metric "proxmox_backup_restore_last_task_timestamp_seconds{node=\"$(escape_label "$NODE")\",operation=\"$(escape_label "$operation")\",status=\"$(escape_label "$status")\"} $ts"
done

write_metric '# HELP proxmox_migration_last_task_timestamp_seconds Last Proxmox migration task start timestamp by status.'
write_metric '# TYPE proxmox_migration_last_task_timestamp_seconds gauge'
jq -r '
  [ .[] | select(.type == "qmigrate" or .type == "vzmigrate") ]
  | group_by(if (.status // "") == "OK" then "ok" else "failed" end)
  | map({status: (if (.[0].status // "") == "OK" then "ok" else "failed" end), ts: (map(.starttime // 0) | max)})
  | .[]
  | "\(.status) \(.ts)"
' <<<"$TASKS_JSON" | while read -r status ts; do
  write_metric "proxmox_migration_last_task_timestamp_seconds{node=\"$(escape_label "$NODE")\",status=\"$(escape_label "$status")\"} $ts"
done

REPLICATION_JSON="$(pvesh get /cluster/replication --output-format json)"
write_metric '# HELP proxmox_replication_jobs Number of Proxmox replication jobs by enabled state.'
write_metric '# TYPE proxmox_replication_jobs gauge'
for enabled in true false; do
  count="$(jq -r --argjson enabled "$enabled" '[.[] | select(((.disable // 0) | tonumber) == (if $enabled then 0 else 1 end))] | length' <<<"$REPLICATION_JSON")"
  write_metric "proxmox_replication_jobs{node=\"$(escape_label "$NODE")\",enabled=\"$enabled\"} $count"
done

write_metric '# HELP proxmox_replication_job_config Proxmox replication job configuration metadata.'
write_metric '# TYPE proxmox_replication_job_config gauge'
jq -r '.[] | [.id, .target, (.rate // ""), (.schedule // ""), (.disable // 0)] | @tsv' <<<"$REPLICATION_JSON" |
while IFS=$'\t' read -r job_id target rate schedule disable; do
  [ -n "$job_id" ] || continue
  [ "$disable" = "0" ] && enabled="true" || enabled="false"
  write_metric "proxmox_replication_job_config{node=\"$(escape_label "$NODE")\",job_id=\"$(escape_label "$job_id")\",target=\"$(escape_label "$target")\",enabled=\"$(escape_label "$enabled")\",rate_mbps=\"$(escape_label "$rate")\",schedule=\"$(escape_label "$schedule")\"} 1"
done

write_metric '# HELP proxmox_transport_metrics_scrape_success Whether the Proxmox transport metrics collector completed successfully.'
write_metric '# TYPE proxmox_transport_metrics_scrape_success gauge'
write_metric "proxmox_transport_metrics_scrape_success{node=\"$(escape_label "$NODE")\"} 1"

chown prometheus:prometheus "$TMP" 2>/dev/null || true
chmod 0644 "$TMP"
mv "$TMP" "$OUT"
